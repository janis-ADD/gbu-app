# SU24 — GBU-App — Environment-Vorlage
# In .env.local (gitignored) eintragen, niemals committen.

# ─── Supabase (Public, im Client erlaubt) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Supabase Service Role (NUR Server-seitig) ──────────────────────────
SUPABASE_SERVICE_ROLE_KEY=

# ─── KI-Provider (NUR Server-seitig) ────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MODEL_FALLBACK=claude-sonnet-4-6

# ─── Feature-Flags ──────────────────────────────────────────────────────
RA_MODULE_ENABLED=true

# ─── Analytics / Tracking (Consent-pflichtig) ───────────────────────────
# Google Analytics 4 — Measurement-ID, z. B. "G-XXXXXXXXXX"
NEXT_PUBLIC_GA_ID=
# Meta Pixel ID — z. B. "123456789012345"
NEXT_PUBLIC_META_PIXEL_ID=
# Site URL für E-Mail-Redirects (Prod-Domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
